void desconto(string paga, string vip, float com){
    if((paga=="a vista" && vip=="sim") || com>=300){
        cout<<"Voce tem direito ao desconto da loja!!!";
    }else{
        cout<<"Realmente sem desconto";
    }
}

int main(){
    string paga,vip;
    float com;

    cout<<"Como deseja pagar? ";
    cin>>paga;

    cout<<"Voce e cliente VIP? ";
    cin>>vip;

    cout<<"Quanto deu sua compra? ";
    cin>>com;

    desconto(paga,vip,com);

    return 0;
}
